{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TranslateGemmaUI",
  "version": "0.1.0",
  "identifier": "me.zhih.translategemmaui",
  "build": {
    "beforeDevCommand": {
      "cwd": "..",
      "script": "bun run build:sidecar",
      "wait": true
    },
    "beforeBuildCommand": {
      "cwd": "..",
      "script": "bun run build:sidecar",
      "wait": true
    },
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Local TranslateGemma desktop app",
    "longDescription": "A Tauri desktop shell that starts the existing TranslateGemmaUI Go web server locally and opens it in a native desktop window.",
    "externalBin": [
      "binaries/translategemma-ui"
    ]
  }
}
